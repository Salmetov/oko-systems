# OKO Systems — environment template.
# Copy to .env and fill in real values. NEVER commit the real .env.

# ---- App ----
APP_BASE_URL=https://your-domain.example
CALLBACK_HOST=127.0.0.1
CALLBACK_PORT=18080
SCHEMA_PATH=/path/to/schema.sql
APP_SESSION_COOKIE=oko_session
APP_SESSION_MAX_AGE_SEC=2592000

# ---- PostgreSQL ----
DATABASE_URL=postgresql://user:password@localhost:5432/oko

# ---- LLM (Anthropic Claude) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8000

# ---- Speech-to-text (Soniox) ----
SONIOX_API_KEY=

# ---- Bitrix24 OAuth (site flow) ----
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
BITRIX_REDIRECT_URI=https://your-domain.example/connect/bitrix
BITRIX_DOMAIN=

# ---- Bitrix24 OAuth (marketplace / embedded app flow) ----
BITRIX_MT_CLIENT_ID=
BITRIX_MT_CLIENT_SECRET=
BITRIX_MT_REDIRECT_URI=https://your-domain.example/connect/bitrix

# ---- Bitrix token auto-refresh ----
AUTO_REFRESH_BUFFER_SEC=300
AUTO_REFRESH_INTERVAL_SEC=60
TOKEN_STORE_PATH=/path/to/tokens.json

# ---- Admin / bootstrap ----
OAUTH_ADMIN_TOKEN=
INTERNAL_BOOTSTRAP_EMAIL=
INTERNAL_BOOTSTRAP_PASSWORD=
PASSWORD_RESET_TTL_SEC=3600

# ---- Email (Mailtrap) ----
MAILTRAP_API_TOKEN=
MAILTRAP_API_BASE_URL=https://send.api.mailtrap.io/api/send
MAILTRAP_FROM_EMAIL=hello@your-domain.example
MAILTRAP_FROM_NAME=OKO Systems

# ---- Telegram (lead/alert bot) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
DEMO_NOTIFY_CHAT_ID=
